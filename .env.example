# API Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=true

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ui_ai_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ui_ai_db
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Vector Database Configuration (ChromaDB)
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# LLM API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
