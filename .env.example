# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Crawler Configuration
PLAYWRIGHT_HEADLESS=true
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Logging
LOG_LEVEL=INFO
